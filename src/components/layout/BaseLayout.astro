---
import '../../styles/global.css';
import Sidebar from './Sidebar.astro';

export interface Props {
  title: string;
  description?: string;
  keywords?: string[];
  ogImage?: string;
  canonicalUrl?: string;
  sidebar?: boolean;
}

const {
  title,
  description = '',
  keywords = [],
  ogImage,
  canonicalUrl,
  sidebar = true,
} = Astro.props;

const fullCanonicalUrl = canonicalUrl || new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title data-site-title>{title}</title>
    <meta name="description" content={description} data-page-set={description ? 'true' : ''} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(',')} />}
    <link rel="canonical" href={fullCanonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={fullCanonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <script is:inline>
      (function() {
        const t = localStorage.getItem('theme');
        if (t) document.documentElement.setAttribute('data-theme', t);
        else if (window.matchMedia('(prefers-color-scheme: dark)').matches) document.documentElement.setAttribute('data-theme', 'dark');
        else document.documentElement.setAttribute('data-theme', 'light');
        const l = localStorage.getItem('locale');
        if (l) document.documentElement.setAttribute('data-locale', l);
        else document.documentElement.setAttribute('data-locale', navigator.language.toLowerCase().startsWith('zh') ? 'zh' : 'en');
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <nav class="header-nav container">
        <a href="/" class="site-logo">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
          <span id="site-logo-text">Blog</span>
        </a>
        <div class="nav-links">
          <a href="/" data-i18n="nav.home">首页</a>
          <a href="/articles" data-i18n="nav.articles">文章</a>
          <a href="/archives" data-i18n="nav.archives">归档</a>
          <a href="/about" data-i18n="nav.about">关于</a>
        </div>
        <div class="nav-actions">
          <a href="/search" class="nav-icon" aria-label="搜索">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </a>
          <button class="nav-icon" id="locale-toggle-btn" aria-label="切换语言" title="中文/English">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
          </button>
          <button class="nav-icon" id="theme-toggle-btn" aria-label="切换主题">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
          </button>
        </div>
      </nav>
    </header>

    <main class:list={['page-layout', !sidebar && 'no-sidebar']}>
      <div class="main-content">
        <slot />
      </div>
      {sidebar && (
        <aside class="sidebar">
          <slot name="sidebar"><Sidebar /></slot>
        </aside>
      )}
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p id="footer-text">&copy; {new Date().getFullYear()} Blog</p>
        <a href="/rss.xml">RSS</a>
      </div>
    </footer>

    <script>
      document.getElementById('theme-toggle-btn')?.addEventListener('click', () => {
        const cur = document.documentElement.getAttribute('data-theme') || 'light';
        const next = cur === 'light' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });

      document.getElementById('locale-toggle-btn')?.addEventListener('click', () => {
        const cur = document.documentElement.getAttribute('data-locale') || 'zh';
        const next = cur === 'zh' ? 'en' : 'zh';
        document.documentElement.setAttribute('data-locale', next);
        localStorage.setItem('locale', next);
        applyLocale(next);
      });

      async function applyLocale(locale: string) {
        const { initLocale, t, setLocale } = await import('../../utils/i18n');
        setLocale(locale);

        document.querySelectorAll('[data-i18n]').forEach(el => {
          const key = el.getAttribute('data-i18n');
          if (key) el.textContent = t(key);
        });

        document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
          const key = el.getAttribute('data-i18n-placeholder');
          if (key) el.setAttribute('placeholder', t(key));
        });
      }

      const savedLocale = localStorage.getItem('locale') || (navigator.language.toLowerCase().startsWith('zh') ? 'zh' : 'en');
      if (savedLocale !== 'zh') applyLocale(savedLocale);

      (async function() {
        try {
          const res = await fetch('/api/v1/config');
          const data = await res.json();
          if (data.code !== 0 || !data.data) return;
          const cfg = data.data;

          const logoText = document.getElementById('site-logo-text');
          if (logoText && cfg.site_title) logoText.textContent = cfg.site_title;

          const footerText = document.getElementById('footer-text');
          if (footerText && cfg.site_title) footerText.textContent = `\u00A9 ${new Date().getFullYear()} ${cfg.site_title}`;

          const titleEl = document.querySelector('title[data-site-title]');
          if (titleEl) {
            const current = titleEl.textContent || '';
            if (current === '首页' && cfg.site_title) {
              titleEl.textContent = cfg.site_title;
            } else if (cfg.site_title) {
              titleEl.textContent = current.replace('Blog', cfg.site_title);
            }
          }

          const metaDesc = document.querySelector('meta[name="description"]');
          if (metaDesc && !metaDesc.getAttribute('data-page-set') && cfg.site_description) {
            metaDesc.setAttribute('content', cfg.site_description);
          }

          const ogDesc = document.querySelector('meta[property="og:description"]');
          if (ogDesc && !metaDesc?.getAttribute('data-page-set') && cfg.site_description) {
            ogDesc.setAttribute('content', cfg.site_description);
          }

          const heroTitle = document.getElementById('hero-site-title');
          if (heroTitle && cfg.site_title) heroTitle.textContent = cfg.site_title;

          const heroSubtitle = document.getElementById('hero-site-subtitle');
          if (heroSubtitle && cfg.site_subtitle) heroSubtitle.textContent = cfg.site_subtitle;

          const heroDesc = document.getElementById('hero-site-desc');
          if (heroDesc && cfg.site_description) heroDesc.textContent = cfg.site_description;
        } catch {}
      })();
    </script>
  </body>
</html>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-height);
    background: rgba(250, 250, 250, 0.8);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--color-border-light);
    z-index: 100;
  }
  [data-theme="dark"] .site-header {
    background: rgba(10, 10, 10, 0.8);
  }
  .header-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }
  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-primary);
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
  }
  .site-logo:hover {
    color: var(--color-accent);
  }
  .site-logo svg {
    color: var(--color-accent);
  }
  .nav-links {
    display: flex;
    gap: 0.25rem;
  }
  .nav-links a {
    padding: 0.4rem 0.75rem;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }
  .nav-links a:hover {
    color: var(--color-text-primary);
    background: var(--color-accent-subtle);
  }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .nav-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    color: var(--color-text-secondary);
    transition: all var(--transition-fast);
  }
  .nav-icon:hover {
    color: var(--color-text-primary);
    background: var(--color-accent-subtle);
  }
  @media (max-width: 767px) {
    .nav-links { display: none; }
  }
  .site-footer {
    border-top: 1px solid var(--color-border-light);
    padding: 2rem 0;
    margin-top: 6rem;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--color-text-tertiary);
    font-size: 0.8rem;
  }
  .footer-inner a {
    color: var(--color-text-tertiary);
    font-size: 0.8rem;
  }
  .footer-inner a:hover {
    color: var(--color-accent);
  }
</style>
