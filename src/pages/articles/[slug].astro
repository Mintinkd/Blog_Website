---
import BaseLayout from '../../components/layout/BaseLayout.astro';

export const prerender = false;

const { slug } = Astro.params;
---

<BaseLayout title="文章详情" description="">
  <article class="article-detail" id="article-detail" data-slug={slug}>
    <div class="article-loading">
      <div class="loading-spinner"></div>
      <p data-i18n="article.loading">加载文章中...</p>
    </div>
  </article>
</BaseLayout>

<style>
  .article-detail {
    max-width: 760px;
    margin: 0 auto;
  }

  .article-loading {
    text-align: center;
    color: var(--color-text-tertiary);
    padding: 5rem 0;
  }

  .loading-spinner {
    width: 24px;
    height: 24px;
    border: 2px solid var(--color-border);
    border-top-color: var(--color-accent);
    border-radius: 50%;
    margin: 0 auto 1rem;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  import { t, getLocale } from '../../utils/i18n.ts';

  async function loadArticle() {
    const container = document.getElementById('article-detail');
    if (!container) return;

    const slug = container.dataset.slug;
    if (!slug) return;

    const locale = getLocale();
    const dateLocale = locale === 'zh' ? 'zh-CN' : 'en-US';

    try {
      const response = await fetch(`/api/v1/articles/${slug}`);
      const data = await response.json();

      if (data.code === 0 && data.data) {
        const article = data.data;

        document.title = `${article.title} | Blog`;

        const metaDesc = document.querySelector('meta[name="description"]');
        if (metaDesc) metaDesc.setAttribute('content', article.summary || article.title);

        container.innerHTML = `
          <header class="article-header">
            <div class="article-meta-top">
              ${article.category ? `<a href="/categories/${article.category.slug}" class="article-category">${article.category.name}</a>` : ''}
              <span class="article-date">${article.published_at ? new Date(article.published_at).toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' }) : ''}</span>
            </div>
            <h1 class="article-title">${article.title}</h1>
            ${article.summary ? `<p class="article-summary">${article.summary}</p>` : ''}
            <div class="article-meta-bottom">
              <span class="meta-item">${article.view_count} ${t('article.views')}</span>
              <span class="meta-item">${article.like_count} ${t('article.likes')}</span>
              <span class="meta-item">${article.reading_time || 5} ${t('article.minutes_read')}</span>
            </div>
            <div class="article-tags">
              ${(article.tags || []).map((tag: any) => `<a href="/tags/${tag.slug}" class="article-tag">${tag.name}</a>`).join('')}
            </div>
          </header>
          <div class="article-content prose">${article.content_html || article.content}</div>
          <div class="article-actions">
            <div id="like-button-mount" data-article-id="${article.id}"></div>
          </div>
          <div id="comment-section-mount" data-article-id="${article.id}"></div>
        `;
      } else {
        container.innerHTML = `<div class="article-not-found"><h2>${t('article.not_found')}</h2><p>${t('article.check_link')}</p><a href="/" class="back-link">${t('article.back_home')}</a></div>`;
      }
    } catch (e) {
      container.innerHTML = `<div class="article-not-found"><p>${t('article.load_error')}</p><a href="/" class="back-link">${t('article.back_home')}</a></div>`;
    }
  }

  loadArticle();

  document.addEventListener('locale-changed', () => loadArticle());
</script>

<style is:global>
  .article-header {
    margin-bottom: 2.5rem;
  }

  .article-meta-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    font-size: 0.85rem;
  }

  .article-category {
    color: var(--color-accent);
    font-weight: 500;
  }

  .article-date {
    color: var(--color-text-tertiary);
  }

  .article-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.3;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .article-summary {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .article-meta-bottom {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    color: var(--color-text-tertiary);
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .article-tag {
    padding: 0.15rem 0.6rem;
    background-color: var(--color-tag-bg);
    color: var(--color-tag-text);
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    transition: all var(--transition-fast);
  }

  .article-tag:hover {
    background-color: var(--color-accent-light);
    color: var(--color-accent);
  }

  .article-actions {
    display: flex;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border-light);
  }

  .article-not-found {
    text-align: center;
    padding: 4rem 0;
    color: var(--color-text-secondary);
  }

  .article-not-found h2 {
    font-size: 1.5rem;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }

  .article-not-found p {
    margin-bottom: 1.5rem;
  }

  .back-link {
    display: inline-block;
    padding: 0.5rem 1.2rem;
    background-color: var(--color-accent);
    color: #fff;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    font-weight: 500;
  }

  .back-link:hover {
    background-color: var(--color-accent-hover);
    color: #fff;
  }

  @media (max-width: 639px) {
    .article-title {
      font-size: 1.5rem;
    }
  }
</style>
