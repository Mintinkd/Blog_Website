---
import BaseLayout from '../../components/layout/BaseLayout.astro';

export async function getStaticPaths() {
  return [];
}

const { slug } = Astro.params;
---

<BaseLayout title="文章详情" description="">
  <article class="article-detail" id="article-detail" data-slug={slug}>
    <p class="loading-text">加载文章中...</p>
  </article>
</BaseLayout>

<style>
  .article-detail {
    max-width: 800px;
    margin: 0 auto;
  }

  .loading-text {
    text-align: center;
    color: var(--color-text-tertiary);
    padding: 4rem 0;
  }

  :global(.article-detail .article-header) {
    margin-bottom: 2rem;
  }

  :global(.article-detail .article-title) {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.3;
    margin-bottom: 1rem;
  }

  :global(.article-detail .article-meta) {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  :global(.article-detail .article-actions) {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }
</style>

<script>
  async function loadArticle() {
    const container = document.getElementById('article-detail');
    if (!container) return;

    const slug = container.dataset.slug;
    if (!slug) return;

    try {
      const response = await fetch(`/api/v1/articles/${slug}`);
      const data = await response.json();

      if (data.code === 0 && data.data) {
        const article = data.data;

        document.title = `${article.title} | Smart Learn Assistant`;

        const metaDesc = document.querySelector('meta[name="description"]');
        if (metaDesc) metaDesc.setAttribute('content', article.summary || article.title);

        container.innerHTML = `
          <header class="article-header">
            <h1 class="article-title">${article.title}</h1>
            <div class="article-meta">
              <span>${article.published_at ? new Date(article.published_at).toLocaleDateString('zh-CN') : ''}</span>
              ${article.category ? `<a href="/categories/${article.category.slug}">${article.category.name}</a>` : ''}
              <span>${article.view_count} 次阅读</span>
              <span>${article.like_count} 赞</span>
            </div>
            <div class="article-tags">
              ${(article.tags || []).map((t: any) => `<a href="/tags/${t.slug}" class="tag">${t.name}</a>`).join('')}
            </div>
          </header>
          <div class="article-content prose">${article.content_html || article.content}</div>
          <div class="article-actions">
            <div id="like-button-mount" data-article-id="${article.id}"></div>
          </div>
          <div id="comment-section-mount" data-article-id="${article.id}"></div>
        `;
      } else {
        container.innerHTML = '<p>文章未找到</p>';
      }
    } catch (e) {
      container.innerHTML = '<p class="error-text">加载失败，请刷新重试</p>';
    }
  }

  loadArticle();
</script>