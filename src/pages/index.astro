---
import BaseLayout from '../components/layout/BaseLayout.astro';

---

<BaseLayout title="首页">
  <section class="hero">
    <div class="hero-inner">
      <h1 class="hero-title" id="hero-site-title">探索 · 记录 · 分享</h1>
      <p class="hero-subtitle" id="hero-site-subtitle">关于技术、生活与思考的个人空间</p>
      <p class="hero-desc" id="hero-site-desc"></p>
      <div class="hero-actions">
        <a href="/articles" class="hero-btn primary">浏览文章</a>
        <a href="/about" class="hero-btn secondary">了解更多</a>
      </div>
    </div>
  </section>

  <section class="article-section">
    <div class="section-header">
      <h2 class="section-title">最新文章</h2>
      <a href="/articles" class="section-link">查看全部 →</a>
    </div>
    <div id="article-list" data-page="1" data-page-size="6">
      <div class="article-grid" id="article-grid"></div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0 3rem;
    position: relative;
  }

  .hero-inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .hero-title {
    font-size: 2.75rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .hero-desc {
    font-size: 0.95rem;
    color: var(--color-text-tertiary);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .hero-desc:empty {
    display: none;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.5rem;
    border-radius: var(--radius-md);
    font-size: 0.9rem;
    font-weight: 500;
    transition: all var(--transition-fast);
  }

  .hero-btn.primary {
    background-color: var(--color-accent);
    color: #fff;
  }

  .hero-btn.primary:hover {
    background-color: var(--color-accent-hover);
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
  }

  .hero-btn.secondary {
    background-color: var(--color-bg-secondary);
    color: var(--color-text-primary);
    border: 1px solid var(--color-border);
  }

  .hero-btn.secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .article-section {
    margin-top: 1rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
  }

  .section-link {
    font-size: 0.85rem;
    color: var(--color-text-tertiary);
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .section-link:hover {
    color: var(--color-accent);
  }

  .article-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 639px) {
    .hero-title {
      font-size: 2rem;
    }
    .hero-subtitle {
      font-size: 1rem;
    }
  }
</style>

<script>
  async function loadArticles() {
    const container = document.getElementById('article-grid');
    if (!container) return;

    try {
      const page = 1;
      const pageSize = 6;

      const response = await fetch(`/api/v1/articles?page=${page}&page_size=${pageSize}&status=published`);
      const data = await response.json();

      if (data.code === 0 && data.data) {
        const { items } = data.data;

        if (items.length === 0) {
          container.innerHTML = '<p class="empty-text" style="grid-column:1/-1;text-align:center;color:var(--color-text-tertiary);padding:3rem 0;">暂无文章，敬请期待</p>';
          return;
        }

        container.innerHTML = items.map((article: any) => `
          <article class="article-card">
            <a href="/articles/${article.slug}" class="card-link">
              <div class="card-body">
                <div class="card-meta">
                  ${article.category ? `<span class="card-category">${article.category.name}</span>` : ''}
                  <span class="card-date">${article.published_at ? new Date(article.published_at).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }) : ''}</span>
                </div>
                <h3 class="card-title">${article.title}</h3>
                <p class="card-summary">${article.summary || ''}</p>
                <div class="card-footer">
                  <div class="card-tags">
                    ${(article.tags || []).slice(0, 2).map((tag: any) => `<span class="card-tag">${tag.name}</span>`).join('')}
                  </div>
                  <span class="card-read">${article.view_count || 0} 阅读</span>
                </div>
              </div>
            </a>
          </article>
        `).join('');
      }
    } catch (e) {
      container.innerHTML = '<p class="error-text" style="grid-column:1/-1;text-align:center;color:var(--color-text-tertiary);padding:3rem 0;">加载失败，请刷新重试</p>';
    }
  }

  loadArticles();
</script>

<style is:global>
  .article-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-normal);
  }

  .article-card:hover {
    border-color: var(--color-border);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    min-height: 200px;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    font-size: 0.8rem;
  }

  .card-category {
    color: var(--color-accent);
    font-weight: 500;
  }

  .card-date {
    color: var(--color-text-tertiary);
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.4;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-summary {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .card-tag {
    padding: 0.1rem 0.5rem;
    background-color: var(--color-tag-bg);
    color: var(--color-tag-text);
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
  }

  .card-read {
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    white-space: nowrap;
  }
</style>
