---
import BaseLayout from '../components/layout/BaseLayout.astro';
---

<BaseLayout title="归档" description="按时间归档的所有文章">
  <section class="archives-page">
    <div class="page-header">
      <h1 class="page-title">归档</h1>
      <p class="page-desc">按时间线浏览所有文章</p>
    </div>
    <div id="archives-list">
      <div class="loading-placeholder">
        <div class="loading-spinner"></div>
        <p>加载归档中...</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 0.35rem;
  }

  .page-desc {
    font-size: 0.9rem;
    color: var(--color-text-tertiary);
  }

  .loading-placeholder {
    text-align: center;
    color: var(--color-text-tertiary);
    padding: 3rem 0;
  }

  .loading-spinner {
    width: 20px;
    height: 20px;
    border: 2px solid var(--color-border);
    border-top-color: var(--color-accent);
    border-radius: 50%;
    margin: 0 auto 0.75rem;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  async function loadArchives() {
    const container = document.getElementById('archives-list');
    if (!container) return;

    try {
      const response = await fetch('/api/v1/articles?page_size=1000&status=published');
      const data = await response.json();

      if (data.code === 0 && data.data) {
        const articles = data.data.items;

        if (articles.length === 0) {
          container.innerHTML = '<p style="text-align:center;color:var(--color-text-tertiary);padding:3rem 0;">暂无文章</p>';
          return;
        }

        const grouped: Record<string, Record<string, any[]>> = {};
        for (const article of articles) {
          const date = article.published_at || article.created_at;
          const d = new Date(date);
          const year = d.getFullYear().toString();
          const month = (d.getMonth() + 1).toString().padStart(2, '0');

          if (!grouped[year]) grouped[year] = {};
          if (!grouped[year][month]) grouped[year][month] = [];
          grouped[year][month].push(article);
        }

        let html = '';
        const years = Object.keys(grouped).sort((a, b) => Number(b) - Number(a));

        for (const year of years) {
          const yearCount = Object.values(grouped[year]).reduce((sum, m) => sum + m.length, 0);
          html += `<div class="archive-year-group">`;
          html += `<h2 class="archive-year">${year}<span class="archive-year-count">${yearCount} 篇</span></h2>`;
          const months = Object.keys(grouped[year]).sort((a, b) => Number(b) - Number(a));

          for (const month of months) {
            html += `<div class="archive-month-group">`;
            html += `<h3 class="archive-month">${month}月</h3>`;
            html += '<ul class="archive-list">';
            for (const article of grouped[year][month]) {
              const date = new Date(article.published_at || article.created_at);
              const dateStr = `${(date.getMonth() + 1).toString().padStart(2, '0')}-${date.getDate().toString().padStart(2, '0')}`;
              html += `<li><span class="archive-date">${dateStr}</span><a href="/articles/${article.slug}">${article.title}</a></li>`;
            }
            html += '</ul></div>';
          }

          html += '</div>';
        }

        container.innerHTML = html;
      }
    } catch (e) {
      container.innerHTML = '<p style="text-align:center;color:var(--color-text-tertiary);padding:3rem 0;">加载失败</p>';
    }
  }

  loadArchives();
</script>

<style is:global>
  .archive-year-group {
    margin-bottom: 2rem;
  }

  .archive-year {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    letter-spacing: -0.01em;
  }

  .archive-year-count {
    font-size: 0.8rem;
    font-weight: 400;
    color: var(--color-text-tertiary);
  }

  .archive-month-group {
    margin-bottom: 1rem;
  }

  .archive-month {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
    padding-left: 1rem;
  }

  .archive-list {
    list-style: none;
    padding-left: 1rem;
    border-left: 2px solid var(--color-border-light);
  }

  .archive-list li {
    padding: 0.35rem 0 0.35rem 1.25rem;
    position: relative;
  }

  .archive-list li::before {
    content: '';
    position: absolute;
    left: -6px;
    top: 0.7rem;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--color-bg-secondary);
    border: 2px solid var(--color-accent);
  }

  .archive-list a {
    color: var(--color-text-primary);
    font-size: 0.9rem;
    transition: color var(--transition-fast);
  }

  .archive-list a:hover {
    color: var(--color-accent);
  }

  .archive-date {
    color: var(--color-text-tertiary);
    font-size: 0.8rem;
    margin-right: 0.75rem;
    font-variant-numeric: tabular-nums;
  }
</style>
