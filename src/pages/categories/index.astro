---
import BaseLayout from '../../components/layout/BaseLayout.astro';

export const prerender = false;
---

<BaseLayout title="分类" description="">
  <section class="categories-page">
    <div class="page-header">
      <h1 class="page-title" data-i18n="page.categories">分类</h1>
    </div>
    <p class="page-desc" data-i18n="page.categories_desc">按分类浏览所有文章</p>
    <div id="categories-cloud" class="categories-cloud">
      <div class="categories-loading" data-i18n="common.loading">加载中...</div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 0.5rem;
  }
  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }
  .page-desc {
    color: var(--color-text-tertiary);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }
  .categories-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }
  .category-item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.9rem 1.1rem;
    min-width: 180px;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all var(--transition-fast);
  }
  .category-item:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateY(-1px);
  }
  .category-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .category-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }
  .category-item:hover .category-name {
    color: var(--color-accent);
  }
  .category-count {
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    white-space: nowrap;
  }
  .category-desc {
    font-size: 0.8rem;
    color: var(--color-text-tertiary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .categories-loading,
  .categories-empty {
    color: var(--color-text-tertiary);
    font-size: 0.9rem;
  }
</style>

<script>
  import { t, getLocale } from '../../utils/i18n.ts';

  function esc(s: string): string {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  async function loadCategories() {
    const container = document.getElementById('categories-cloud');
    if (!container) return;

    try {
      const response = await fetch('/api/v1/categories');
      const data = await response.json();

      if (data.code === 0 && data.data) {
        const categories = Array.isArray(data.data) ? data.data : (data.data.items || []);
        if (categories.length === 0) {
          container.innerHTML = `<p class="categories-empty">${t('page.no_categories')}</p>`;
          return;
        }

        // 按文章数降序
        categories.sort((a: any, b: any) => (b.article_count || 0) - (a.article_count || 0));

        container.innerHTML = categories.map((cat: any) => `
          <a href="/categories/${cat.slug}" class="category-item">
            <div class="category-head">
              <span class="category-name">${esc(cat.name)}</span>
              <span class="category-count">${cat.article_count || 0} ${t('admin.article_count')}</span>
            </div>
            ${cat.description ? `<span class="category-desc">${esc(cat.description)}</span>` : ''}
          </a>
        `).join('');
      } else {
        container.innerHTML = `<p class="categories-empty">${t('common.load_failed')}</p>`;
      }
    } catch (e) {
      container.innerHTML = `<p class="categories-empty">${t('common.load_failed')}</p>`;
    }
  }

  loadCategories();
  document.addEventListener('locale-changed', () => loadCategories());
</script>
