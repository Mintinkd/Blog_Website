---
import BaseLayout from '../components/layout/BaseLayout.astro';
import SearchBox from '../islands/SearchBox.vue';
---

<BaseLayout title="搜索" description="搜索文章">
  <section class="search-page">
    <div class="page-header">
      <h1 class="page-title" data-i18n="page.search">搜索</h1>
      <p class="page-desc" data-i18n="page.search_desc">搜索你感兴趣的内容</p>
    </div>
    <div class="search-container">
      <SearchBox client:load />
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 0.35rem;
  }

  .page-desc {
    font-size: 0.9rem;
    color: var(--color-text-tertiary);
  }

  .search-container {
    max-width: 640px;
  }
</style>
