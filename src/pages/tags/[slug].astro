---
import BaseLayout from '../../components/layout/BaseLayout.astro';

export async function getStaticPaths() {
  return [];
}

const { slug } = Astro.params;
---

<BaseLayout title={`标签: ${slug}`} description="">
  <section class="tag-page">
    <h1 class="page-title" id="tag-title">标签: {slug}</h1>
    <div id="article-list" data-tag-slug={slug} data-page="1" data-page-size="10">
      <p class="loading-text">加载文章中...</p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-title {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--color-text-primary);
  }
  .loading-text {
    text-align: center;
    color: var(--color-text-tertiary);
    padding: 2rem;
  }
</style>