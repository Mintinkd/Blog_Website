---
import BaseLayout from '../../components/layout/BaseLayout.astro';

export const prerender = false;

const { slug } = Astro.params;
---

<BaseLayout title={`标签: ${slug}`} description="">
  <section class="tag-page">
    <div class="page-header">
      <h1 class="page-title" data-i18n="page.tag" data-i18n-params='{"name":""}'>标签: {slug}</h1>
      <a href="/articles" class="page-back" data-i18n="page.all_articles">← 所有文章</a>
    </div>
    <div id="article-list" data-tag-slug={slug} data-page="1" data-page-size="10">
      <div class="article-list-inner"></div>
      <div id="pagination-mount"></div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }

  .page-back {
    font-size: 0.85rem;
    color: var(--color-text-tertiary);
    transition: color var(--transition-fast);
  }

  .page-back:hover {
    color: var(--color-accent);
  }

  .article-list-inner {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
</style>

<script>
  import { t, getLocale } from '../../utils/i18n.ts';

  function esc(s: unknown): string {
    return String(s ?? '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c] as string));
  }

  async function loadArticles(page = 1) {
    const container = document.querySelector('.article-list-inner');
    if (!container) return;
    const wrapper = document.getElementById('article-list');
    if (!wrapper) return;

    const tagSlug = wrapper.dataset.tagSlug;
    const pageSize = 10;
    const locale = getLocale();
    const dateLocale = locale === 'zh' ? 'zh-CN' : 'en-US';

    try {
      const response = await fetch(`/api/v1/articles?page=${page}&page_size=${pageSize}&status=published&tag_slug=${tagSlug}`);
      const data = await response.json();

      if (data.code === 0 && data.data) {
        const { items, total_pages } = data.data;

        if (items.length === 0) {
          container.innerHTML = `<p style="text-align:center;color:var(--color-text-tertiary);padding:3rem 0;">${t('page.no_articles_tag')}</p>`;
          return;
        }

        container.innerHTML = items.map((article: any) => `
          <article class="list-card">
            <a href="/articles/${article.slug}" class="list-card-link">
              <div class="list-card-body">
                <div class="list-card-meta">
                  ${article.category ? `<span class="list-card-category">${article.category.name}</span>` : ''}
                  <span class="list-card-date">${article.published_at ? new Date(article.published_at).toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' }) : ''}</span>
                </div>
                <h3 class="list-card-title">${article.title}</h3>
                ${article.summary ? `<p class="list-card-summary">${article.summary}</p>` : ''}
                <div class="list-card-footer">
                  <div class="list-card-tags">
                    ${(article.tags || []).slice(0, 3).map((tag: any) => `<a href="/tags/${tag.slug}" class="list-card-tag">${esc(tag.name)}</a>`).join('')}
                  </div>
                  <span class="list-card-stats">${article.view_count || 0} ${t('article.read')}</span>
                </div>
              </div>
            </a>
          </article>
        `).join('');

        const paginationMount = document.getElementById('pagination-mount');
        if (paginationMount && total_pages > 1) {
          let pagHtml = '<div class="pagination">';
          if (page > 1) pagHtml += `<button class="pag-btn" data-page="${page - 1}">${t('page.prev')}</button>`;
          pagHtml += `<span class="pag-info">${page} / ${total_pages}</span>`;
          if (page < total_pages) pagHtml += `<button class="pag-btn" data-page="${page + 1}">${t('page.next')}</button>`;
          pagHtml += '</div>';
          paginationMount.innerHTML = pagHtml;

          paginationMount.querySelectorAll('.pag-btn').forEach(btn => {
            btn.addEventListener('click', () => {
              const p = parseInt((btn as HTMLElement).dataset.page || '1', 10);
              loadArticles(p);
              window.scrollTo({ top: 0, behavior: 'smooth' });
            });
          });
        }
      }
    } catch (e) {
      container.innerHTML = `<p style="text-align:center;color:var(--color-text-tertiary);padding:3rem 0;">${t('common.load_failed')}</p>`;
    }
  }

  loadArticles();

  document.addEventListener('locale-changed', () => loadArticles());
</script>

<style is:global>
  .list-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    transition: all var(--transition-normal);
  }
  .list-card:hover {
    border-color: var(--color-border);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-1px);
  }
  .list-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .list-card-body {
    padding: 1.25rem 1.5rem;
  }
  .list-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    font-size: 0.8rem;
  }
  .list-card-category {
    color: var(--color-accent);
    font-weight: 500;
  }
  .list-card-date {
    color: var(--color-text-tertiary);
  }
  .list-card-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.4;
    margin-bottom: 0.35rem;
  }
  .list-card-summary {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }
  .list-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .list-card-tags {
    display: flex;
    gap: 0.35rem;
  }
  .list-card-tag {
    padding: 0.1rem 0.5rem;
    background-color: var(--color-tag-bg);
    color: var(--color-tag-text);
    border-radius: var(--radius-sm);
    font-size: 0.72rem;
  }
  .list-card-stats {
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    white-space: nowrap;
  }
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border-light);
  }
  .pag-btn {
    padding: 0.45rem 1rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-primary);
    font-size: 0.85rem;
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  .pag-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .pag-info {
    font-size: 0.85rem;
    color: var(--color-text-tertiary);
  }
</style>
